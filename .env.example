# ─────────────────────────────────────────────────────────────
# Vikas Tool Mart — CROS — Environment Template
# Copy to .env and fill in. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────

# --- Database (PostgreSQL 16) ---
# When running via docker-compose, host is the service name "postgres".
# For local dev against the docker DB from the host machine, use localhost.
DATABASE_URL="postgresql://vtm:vtm_password@localhost:5432/vtm_cros?schema=public"
POSTGRES_USER="vtm"
POSTGRES_PASSWORD="vtm_password"
POSTGRES_DB="vtm_cros"
# Host-published port for the docker postgres (container port stays 5432).
# Change if 5432 is already in use locally (then match it in DATABASE_URL).
POSTGRES_PORT="5432"

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# --- App encryption key for WooCommerce secrets at rest (AES-256-GCM) ---
# MUST be 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# --- Seed credentials (printed once on seed; change after first login) ---
SEED_ADMIN_EMAIL="md@vikastoolmart.test"
SEED_ADMIN_PASSWORD="ChangeMe!Admin1"
SEED_HEAD_EMAIL="indhumathi@vikastoolmart.test"
SEED_HEAD_PASSWORD="ChangeMe!Head1"
SEED_CRE_EMAIL="cre@vikastoolmart.test"
SEED_CRE_PASSWORD="ChangeMe!Cre1"

# --- WooCommerce (read-only). Can also be set later via Admin UI. ---
# Leave blank to configure in-app. Store URL example: https://vikastoolmart.com
WOO_STORE_URL=""
WOO_CONSUMER_KEY=""
WOO_CONSUMER_SECRET=""

# --- Sync schedule (cron expression for the worker) ---
# Default: 06:30 every day. The worker reads this; admin can also override in DB.
SYNC_CRON="30 6 * * *"

# --- Feature flags ---
# Daily email report via Resend (P1.5, off by default)
FEATURE_EMAIL_REPORTS="false"
RESEND_API_KEY=""
REPORT_FROM_EMAIL="reports@vikastoolmart.test"

# --- Node ---
NODE_ENV="development"
